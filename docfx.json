{
  "metadata": [
    {
      "src": [
        {
          "src": ".",
          "files": [
            "BLL/bin/Debug/net472/BLL.dll",
            "DAL/bin/Debug/net472/DAL.dll",
            "Domain/bin/Debug/Domain.dll",
            "Service/bin/Debug/Service.dll",
            "TpIngSoftware_GestionDeEspaciosDeportivos/bin/Debug/TpIngSoftware_GestionDeEspaciosDeportivos.exe"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**/*.yml", "api/index.md", "index.md", "toc.yml"]
      }
    ],
    "resource": [
      { "files": ["images/**"] }
    ],
    "output": "_site",
    "template": ["default", "modern", "statictoc"],
    "globalMetadata": {
      "_appName": "Gestión de Espacios Deportivos",
      "_appTitle": "Manual de Programador",
      "_enableSearch": false,
      "_enableNavigation": true
    }
  }
}