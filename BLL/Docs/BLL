<?xml version="1.0"?>
<doc>
    <assembly>
        <name>BLL</name>
    </assembly>
    <members>
        <member name="T:BLL.BalanceService">
            <summary>
            Manages client account balances: periodic membership billing, balance enquiry,
            debt validation, and movement history.
            </summary>
        </member>
        <member name="M:BLL.BalanceService.#ctor">
            <summary>Initializes the service with a new <see cref="T:Service.Logic.BitacoraService"/> instance.</summary>
        </member>
        <member name="M:BLL.BalanceService.CalcularSaldoMensual">
            <summary>
            Iterates over all clients in parallel and inserts a <c>DeudaMembresia</c> movement for
            those whose <c>ProximaFechaPago</c> has passed. Advances <c>ProximaFechaPago</c> by
            the membership's <c>Regularidad</c> days after each charge.
            Clients without a membership, with an inactive or free membership, or whose next
            payment date is still in the future are skipped silently.
            </summary>
        </member>
        <member name="M:BLL.BalanceService.ConsultarBalance(System.Guid)">
            <summary>
            Retrieves the current balance for a client from the <c>vw_Balance</c> SQL view.
            </summary>
            <param name="clienteId">The client identifier.</param>
            <returns>The <see cref="T:Domain.Entities.Balance"/> record, or <c>null</c> if no movements exist.</returns>
        </member>
        <member name="M:BLL.BalanceService.ValidarDeuda(System.Guid,System.String)">
            <summary>
            Throws if the client's balance is negative, optionally prefixing the message with a context label.
            Used as a guard in operations that require the client to be current on payments.
            </summary>
            <param name="clienteId">The client to validate.</param>
            <param name="contexto">Optional operation name prepended to the error message for clarity.</param>
            <exception cref="T:System.InvalidOperationException">Thrown when the client has an outstanding debt.</exception>
        </member>
        <member name="M:BLL.BalanceService.ListarMovimientos(System.Guid,System.Nullable{System.DateTime},System.Nullable{System.DateTime})">
            <summary>
            Returns the ledger movement history for a client, optionally filtered by date range.
            </summary>
            <param name="clienteId">The client whose movements to fetch.</param>
            <param name="desde">Optional inclusive lower bound on movement date.</param>
            <param name="hasta">Optional inclusive upper bound on movement date.</param>
        </member>
        <member name="T:BLL.DTOs.AgendaDTO">
            <summary>
            Represents a single availability window for a facility space on a given day of the week.
            </summary>
            <remarks>
            Used as the input/output model for <c>AgendaService.ConfigurarAgenda</c>.
            A space may have multiple <see cref="T:BLL.DTOs.AgendaDTO"/> entries per day to model split availability windows.
            <see cref="P:BLL.DTOs.AgendaDTO.DiaSemana"/> follows the <c>DayOfWeek</c> convention: 0 = Sunday … 6 = Saturday.
            Note: windows that cross midnight (i.e., <see cref="P:BLL.DTOs.AgendaDTO.HoraHasta"/> &lt; <see cref="P:BLL.DTOs.AgendaDTO.HoraDesde"/>) are
            not currently supported and will be rejected by the service.
            </remarks>
        </member>
        <member name="P:BLL.DTOs.AgendaDTO.EspacioID">
            <summary>FK to the space whose availability this window defines.</summary>
        </member>
        <member name="P:BLL.DTOs.AgendaDTO.DiaSemana">
            <summary>Day of the week this window applies to (0 = Sunday, 6 = Saturday).</summary>
        </member>
        <member name="P:BLL.DTOs.AgendaDTO.HoraDesde">
            <summary>Start of the availability window (inclusive).</summary>
        </member>
        <member name="P:BLL.DTOs.AgendaDTO.HoraHasta">
            <summary>End of the availability window (exclusive). Must be greater than <see cref="P:BLL.DTOs.AgendaDTO.HoraDesde"/>.</summary>
        </member>
        <member name="T:BLL.DTOs.ClienteDTO">
            <summary>
            Projection of a <c>Cliente</c> entity used across all BLL service boundaries.
            </summary>
            <remarks>
            Combines core identity fields with hydrated membership details and a pre-computed balance
            so that consumers (UI managers, API controllers) never need to issue additional queries.
            <see cref="P:BLL.DTOs.ClienteDTO.Status"/> defaults to <see cref="F:BLL.DTOs.ClienteStatus.Activo"/> on construction.
            </remarks>
        </member>
        <member name="P:BLL.DTOs.ClienteDTO.Id">
            <summary>Primary key of the client record.</summary>
        </member>
        <member name="P:BLL.DTOs.ClienteDTO.Nombre">
            <summary>Client's first name.</summary>
        </member>
        <member name="P:BLL.DTOs.ClienteDTO.Apellido">
            <summary>Client's last name.</summary>
        </member>
        <member name="P:BLL.DTOs.ClienteDTO.DNI">
            <summary>Argentine national identity document number.</summary>
        </member>
        <member name="P:BLL.DTOs.ClienteDTO.FechaNacimiento">
            <summary>Date of birth.</summary>
        </member>
        <member name="P:BLL.DTOs.ClienteDTO.Email">
            <summary>Contact email address.</summary>
        </member>
        <member name="P:BLL.DTOs.ClienteDTO.CreatedAt">
            <summary>Timestamp of record creation.</summary>
        </member>
        <member name="P:BLL.DTOs.ClienteDTO.MembresiaID">
            <summary>FK to the client's currently assigned membership, or <c>null</c> if none.</summary>
        </member>
        <member name="P:BLL.DTOs.ClienteDTO.Razon">
            <summary>
            Textual reason for the current <see cref="P:BLL.DTOs.ClienteDTO.Status"/>.
            Populated when status is <see cref="F:BLL.DTOs.ClienteStatus.Inactivo"/>.
            </summary>
        </member>
        <member name="P:BLL.DTOs.ClienteDTO.Status">
            <summary>Active/inactive status. Defaults to <see cref="F:BLL.DTOs.ClienteStatus.Activo"/>.</summary>
        </member>
        <member name="P:BLL.DTOs.ClienteDTO.ProximaFechaPago">
            <summary>Next scheduled membership billing date, or <c>null</c> when no active membership row exists.</summary>
        </member>
        <member name="P:BLL.DTOs.ClienteDTO.NombreCompleto">
            <summary>Concatenation of <see cref="P:BLL.DTOs.ClienteDTO.Nombre"/> and <see cref="P:BLL.DTOs.ClienteDTO.Apellido"/>.</summary>
        </member>
        <member name="P:BLL.DTOs.ClienteDTO.MembresiaDetalle">
            <summary>Hydrated membership details. Populated by <c>ClienteService.ObtenerCliente</c> when membership exists.</summary>
        </member>
        <member name="P:BLL.DTOs.ClienteDTO.Balance">
            <summary>Current account balance in currency units (positive = credit, negative = debt).</summary>
        </member>
        <member name="P:BLL.DTOs.ClienteDTO.EstadoBalance">
            <summary>Categorized balance state derived from <see cref="P:BLL.DTOs.ClienteDTO.Balance"/>.</summary>
        </member>
        <member name="T:BLL.DTOs.ClienteStatus">
            <summary>
            Indicates whether a client account is active or has been deactivated.
            </summary>
            <remarks>
            Inactive clients are blocked from facility entry by <c>ClienteService.ValidarIngreso</c>
            and from creating new reservations. The status is persisted as an integer column.
            </remarks>
        </member>
        <member name="F:BLL.DTOs.ClienteStatus.Activo">
            <summary>The client account is active and fully operational.</summary>
        </member>
        <member name="F:BLL.DTOs.ClienteStatus.Inactivo">
            <summary>The client account has been deactivated. See <c>ClienteDTO.Razon</c> for the reason.</summary>
        </member>
        <member name="T:BLL.DTOs.ComprobanteDTO">
            <summary>
            Transfer object representing a receipt (comprobante) file attached to a payment or reservation.
            </summary>
            <remarks>
            Either <see cref="P:BLL.DTOs.ComprobanteDTO.PagoID"/> or <see cref="P:BLL.DTOs.ComprobanteDTO.ReservaID"/> must be set to identify the owning entity.
            <see cref="P:BLL.DTOs.ComprobanteDTO.Contenido"/> holds the raw file bytes (typically an HTML receipt generated by
            <c>ComprobanteGenerator</c>). <see cref="P:BLL.DTOs.ComprobanteDTO.RutaArchivo"/> is an optional filesystem path used
            when the file is persisted to disk rather than stored as a BLOB.
            <see cref="P:BLL.DTOs.ComprobanteDTO.Id"/> is auto-assigned on construction.
            </remarks>
        </member>
        <member name="P:BLL.DTOs.ComprobanteDTO.Id">
            <summary>Primary key, auto-assigned on construction.</summary>
        </member>
        <member name="P:BLL.DTOs.ComprobanteDTO.PagoID">
            <summary>FK to the associated payment, or <c>null</c> when linked to a reservation instead.</summary>
        </member>
        <member name="P:BLL.DTOs.ComprobanteDTO.ReservaID">
            <summary>FK to the associated reservation, or <c>null</c> when linked to a payment instead.</summary>
        </member>
        <member name="P:BLL.DTOs.ComprobanteDTO.NombreArchivo">
            <summary>Display file name including extension (e.g., <c>"Payment_Receipt_42.html"</c>).</summary>
        </member>
        <member name="P:BLL.DTOs.ComprobanteDTO.RutaArchivo">
            <summary>Optional filesystem path for disk-backed storage. <c>null</c> when content is stored as <see cref="P:BLL.DTOs.ComprobanteDTO.Contenido"/>.</summary>
        </member>
        <member name="P:BLL.DTOs.ComprobanteDTO.FechaSubida">
            <summary>Timestamp when the receipt was attached. Defaults to <c>DateTime.Now</c> when not set.</summary>
        </member>
        <member name="P:BLL.DTOs.ComprobanteDTO.Contenido">
            <summary>Raw file bytes of the receipt document.</summary>
        </member>
        <member name="T:BLL.DTOs.EjercicioDTO">
            <summary>
            Represents a single exercise entry within a <see cref="T:BLL.DTOs.RutinaDTO"/>.
            </summary>
            <remarks>
            Exercises are scoped to a specific day of the week and ordered within that day via <see cref="P:BLL.DTOs.EjercicioDTO.Orden"/>.
            <see cref="P:BLL.DTOs.EjercicioDTO.Id"/> is auto-assigned on construction.
            </remarks>
        </member>
        <member name="P:BLL.DTOs.EjercicioDTO.Id">
            <summary>Primary key, auto-assigned on construction.</summary>
        </member>
        <member name="P:BLL.DTOs.EjercicioDTO.RutinaID">
            <summary>FK to the parent routine.</summary>
        </member>
        <member name="P:BLL.DTOs.EjercicioDTO.Nombre">
            <summary>Exercise name or description.</summary>
        </member>
        <member name="P:BLL.DTOs.EjercicioDTO.Repeticiones">
            <summary>Number of repetitions to perform.</summary>
        </member>
        <member name="P:BLL.DTOs.EjercicioDTO.DiaSemana">
            <summary>Day of the week this exercise is scheduled for (0 = Sunday, 6 = Saturday).</summary>
        </member>
        <member name="P:BLL.DTOs.EjercicioDTO.Orden">
            <summary>Display order within the day's exercise list (ascending).</summary>
        </member>
        <member name="T:BLL.DTOs.EspacioDTO">
            <summary>
            Projection of a <c>Espacio</c> (sporting space/facility) entity exposed through BLL service boundaries.
            </summary>
        </member>
        <member name="P:BLL.DTOs.EspacioDTO.Id">
            <summary>Primary key of the facility space.</summary>
        </member>
        <member name="P:BLL.DTOs.EspacioDTO.Nombre">
            <summary>Display name of the space (e.g., <c>"Cancha 1"</c>).</summary>
        </member>
        <member name="P:BLL.DTOs.EspacioDTO.Descripcion">
            <summary>Optional description or notes about the space.</summary>
        </member>
        <member name="P:BLL.DTOs.EspacioDTO.PrecioHora">
            <summary>Billing rate per hour in currency units. Used to compute reservation totals.</summary>
        </member>
        <member name="P:BLL.DTOs.EspacioDTO.Estado">
            <summary>Operational status of the space. Only <c>Disponible</c> spaces accept new reservations.</summary>
        </member>
        <member name="T:BLL.DTOs.EstadoBalance">
            <summary>
            Categorized account balance state derived from the numeric balance value.
            </summary>
            <remarks>
            Used by <c>ClienteDTO.EstadoBalance</c> so the UI layer can apply distinct visual
            treatments (color coding, icons) without comparing raw decimal values.
            </remarks>
        </member>
        <member name="F:BLL.DTOs.EstadoBalance.AlDia">
            <summary>Balance is zero: no outstanding debt and no credit.</summary>
        </member>
        <member name="F:BLL.DTOs.EstadoBalance.Deudor">
            <summary>Balance is negative: the client has an outstanding debt.</summary>
        </member>
        <member name="F:BLL.DTOs.EstadoBalance.AFavor">
            <summary>Balance is positive: the client has a credit in their account.</summary>
        </member>
        <member name="T:BLL.DTOs.GenerarReservaDTO">
            <summary>
            Command object carrying all inputs required to create a new reservation via <c>ReservaService.GenerarReserva</c>.
            </summary>
            <remarks>
            <see cref="P:BLL.DTOs.GenerarReservaDTO.Duracion"/> must be a positive integer representing minutes.
            <see cref="P:BLL.DTOs.GenerarReservaDTO.Adelanto"/> is the partial payment collected at booking time; it may be zero but must not be negative.
            Availability is validated against the space's agenda and existing reservations inside the service.
            </remarks>
        </member>
        <member name="P:BLL.DTOs.GenerarReservaDTO.ClienteId">
            <summary>FK to the client making the reservation.</summary>
        </member>
        <member name="P:BLL.DTOs.GenerarReservaDTO.EspacioId">
            <summary>FK to the space being reserved.</summary>
        </member>
        <member name="P:BLL.DTOs.GenerarReservaDTO.FechaHora">
            <summary>Exact start date and time of the requested reservation.</summary>
        </member>
        <member name="P:BLL.DTOs.GenerarReservaDTO.Duracion">
            <summary>Requested duration in minutes.</summary>
        </member>
        <member name="P:BLL.DTOs.GenerarReservaDTO.Adelanto">
            <summary>Advance payment amount to register at the time of booking.</summary>
        </member>
        <member name="T:BLL.DTOs.IngresoDTO">
            <summary>
            Projection of a facility check-in (<c>Ingreso</c>) record with a hydrated client name.
            </summary>
            <remarks>
            Check-in records are written by <c>ClienteService.ValidarIngreso</c> and are read-only
            through <c>IngresoService</c>. <see cref="P:BLL.DTOs.IngresoDTO.ClienteNombre"/> is hydrated at query time;
            it is set to <c>"Desconocido"</c> when the client record cannot be resolved.
            </remarks>
        </member>
        <member name="P:BLL.DTOs.IngresoDTO.Id">
            <summary>Primary key of the check-in record.</summary>
        </member>
        <member name="P:BLL.DTOs.IngresoDTO.ClienteID">
            <summary>FK to the client who checked in.</summary>
        </member>
        <member name="P:BLL.DTOs.IngresoDTO.ClienteNombre">
            <summary>Full name of the client (<c>"Nombre Apellido"</c>), hydrated from the client repository.</summary>
        </member>
        <member name="P:BLL.DTOs.IngresoDTO.FechaHora">
            <summary>Timestamp when the check-in occurred.</summary>
        </member>
        <member name="T:BLL.DTOs.MembresiaDTO">
            <summary>
            Projection of a <c>Membresia</c> entity exposed through BLL service boundaries.
            </summary>
            <remarks>
            <see cref="P:BLL.DTOs.MembresiaDTO.Regularidad"/> expresses the billing cycle in days (e.g., 30 for monthly).
            <see cref="P:BLL.DTOs.MembresiaDTO.PrecioFormateado"/> is a display-only computed property; it is not persisted.
            </remarks>
        </member>
        <member name="P:BLL.DTOs.MembresiaDTO.Id">
            <summary>Primary key of the membership plan.</summary>
        </member>
        <member name="P:BLL.DTOs.MembresiaDTO.Codigo">
            <summary>Auto-incremented sequential code assigned by the database.</summary>
        </member>
        <member name="P:BLL.DTOs.MembresiaDTO.Nombre">
            <summary>Display name of the membership plan.</summary>
        </member>
        <member name="P:BLL.DTOs.MembresiaDTO.Precio">
            <summary>Billing amount per cycle in currency units.</summary>
        </member>
        <member name="P:BLL.DTOs.MembresiaDTO.Regularidad">
            <summary>Billing cycle length in days (e.g., 30 = monthly, 7 = weekly).</summary>
        </member>
        <member name="P:BLL.DTOs.MembresiaDTO.Activa">
            <summary><c>true</c> if the plan is available for assignment to clients.</summary>
        </member>
        <member name="P:BLL.DTOs.MembresiaDTO.Detalle">
            <summary>Optional description or notes about the membership plan.</summary>
        </member>
        <member name="P:BLL.DTOs.MembresiaDTO.PrecioFormateado">
            <summary>Currency-formatted representation of <see cref="P:BLL.DTOs.MembresiaDTO.Precio"/> (e.g., <c>"$1,500.00"</c>).</summary>
        </member>
        <member name="T:BLL.DTOs.PagoDTO">
            <summary>
            Projection of a <c>Pago</c> entity used as both input and output for payment operations.
            </summary>
            <remarks>
            When used as input to <c>PagoService.RegistrarPago</c>, set <see cref="P:BLL.DTOs.PagoDTO.ClienteID"/>,
            <see cref="P:BLL.DTOs.PagoDTO.Monto"/>, <see cref="P:BLL.DTOs.PagoDTO.Metodo"/>, and optionally <see cref="P:BLL.DTOs.PagoDTO.ReservaID"/> or
            <see cref="P:BLL.DTOs.PagoDTO.MembresiaID"/> to indicate the payment type.
            <see cref="P:BLL.DTOs.PagoDTO.Estado"/> is overwritten by the service; callers should not set it.
            <see cref="P:BLL.DTOs.PagoDTO.Id"/> is initialized to a new <see cref="T:System.Guid"/> on construction.
            </remarks>
        </member>
        <member name="P:BLL.DTOs.PagoDTO.Id">
            <summary>Primary key, auto-assigned on construction.</summary>
        </member>
        <member name="P:BLL.DTOs.PagoDTO.Codigo">
            <summary>Auto-incremented sequential code assigned by the database.</summary>
        </member>
        <member name="P:BLL.DTOs.PagoDTO.ClienteID">
            <summary>FK to the client who made the payment.</summary>
        </member>
        <member name="P:BLL.DTOs.PagoDTO.Monto">
            <summary>Payment amount in currency units. Must be positive.</summary>
        </member>
        <member name="P:BLL.DTOs.PagoDTO.Metodo">
            <summary>Payment method label (e.g., <c>"Efectivo"</c>, <c>"Tarjeta"</c>).</summary>
        </member>
        <member name="P:BLL.DTOs.PagoDTO.Detalle">
            <summary>Optional free-text detail or reference number for the payment.</summary>
        </member>
        <member name="P:BLL.DTOs.PagoDTO.Fecha">
            <summary>Timestamp of the payment. Defaults to <c>DateTime.Now</c> when not set.</summary>
        </member>
        <member name="P:BLL.DTOs.PagoDTO.Estado">
            <summary>Payment lifecycle status. Set by the service layer, not by the caller.</summary>
        </member>
        <member name="P:BLL.DTOs.PagoDTO.MembresiaID">
            <summary>FK to the membership being paid, or <c>null</c> for non-membership payments.</summary>
        </member>
        <member name="P:BLL.DTOs.PagoDTO.ReservaID">
            <summary>FK to the reservation being settled, or <c>null</c> for non-reservation payments.</summary>
        </member>
        <member name="P:BLL.DTOs.PagoDTO.EsMembresia">
            <summary><c>true</c> when <see cref="P:BLL.DTOs.PagoDTO.MembresiaID"/> has a value; determines movement type inside <c>PagoService</c>.</summary>
        </member>
        <member name="T:BLL.DTOs.ReservaDTO">
            <summary>
            Projection of a <c>Reserva</c> entity with denormalized client and space names.
            </summary>
            <remarks>
            <see cref="P:BLL.DTOs.ReservaDTO.ClienteNombre"/> and <see cref="P:BLL.DTOs.ReservaDTO.EspacioNombre"/> are hydrated by
            <c>ReservaService.ListarReservas</c> to avoid extra lookups in the UI layer.
            <see cref="P:BLL.DTOs.ReservaDTO.Estado"/> mirrors <c>EstadoReserva</c> as a string so the UI can display
            it without a reference to the Domain enum assembly.
            </remarks>
        </member>
        <member name="P:BLL.DTOs.ReservaDTO.Id">
            <summary>Primary key of the reservation.</summary>
        </member>
        <member name="P:BLL.DTOs.ReservaDTO.ClienteID">
            <summary>FK to the client who made the reservation.</summary>
        </member>
        <member name="P:BLL.DTOs.ReservaDTO.ClienteNombre">
            <summary>Full name of the client, hydrated from the repository.</summary>
        </member>
        <member name="P:BLL.DTOs.ReservaDTO.EspacioID">
            <summary>FK to the reserved space.</summary>
        </member>
        <member name="P:BLL.DTOs.ReservaDTO.EspacioNombre">
            <summary>Display name of the space, hydrated from the repository.</summary>
        </member>
        <member name="P:BLL.DTOs.ReservaDTO.Fecha">
            <summary>Date portion of the reservation (date only, no time component).</summary>
        </member>
        <member name="P:BLL.DTOs.ReservaDTO.FechaHora">
            <summary>Exact start date and time of the reservation.</summary>
        </member>
        <member name="P:BLL.DTOs.ReservaDTO.Duracion">
            <summary>Duration of the reservation in minutes.</summary>
        </member>
        <member name="P:BLL.DTOs.ReservaDTO.Adelanto">
            <summary>Advance payment amount collected at booking time.</summary>
        </member>
        <member name="P:BLL.DTOs.ReservaDTO.CodigoReserva">
            <summary>Human-readable reservation code (e.g., <c>RES-000123</c>).</summary>
        </member>
        <member name="P:BLL.DTOs.ReservaDTO.Estado">
            <summary>String representation of <c>EstadoReserva</c> (e.g., <c>"Pendiente"</c>, <c>"Pagada"</c>, <c>"Cancelada"</c>).</summary>
        </member>
        <member name="T:BLL.DTOs.ResultadoIngresoDTO">
            <summary>
            Result returned by <c>ClienteService.ValidarIngreso</c> describing whether a client is
            permitted to enter the facility and the reason when access is denied.
            </summary>
            <remarks>
            When <see cref="P:BLL.DTOs.ResultadoIngresoDTO.Permitido"/> is <c>false</c>, <see cref="P:BLL.DTOs.ResultadoIngresoDTO.Razon"/> contains a localized
            message suitable for display (e.g., client inactive, outstanding debt).
            <see cref="P:BLL.DTOs.ResultadoIngresoDTO.Balance"/> is always populated so the UI can show the client's account state
            regardless of the access decision.
            </remarks>
        </member>
        <member name="P:BLL.DTOs.ResultadoIngresoDTO.Permitido">
            <summary><c>true</c> if the client is allowed entry and a check-in record was created.</summary>
        </member>
        <member name="P:BLL.DTOs.ResultadoIngresoDTO.Razon">
            <summary>Localized denial reason, or <c>null</c> when <see cref="P:BLL.DTOs.ResultadoIngresoDTO.Permitido"/> is <c>true</c>.</summary>
        </member>
        <member name="P:BLL.DTOs.ResultadoIngresoDTO.NombreCliente">
            <summary>Full name of the client (<c>"Nombre Apellido"</c>).</summary>
        </member>
        <member name="P:BLL.DTOs.ResultadoIngresoDTO.Balance">
            <summary>Current account balance in currency units at the time of the validation.</summary>
        </member>
        <member name="T:BLL.DTOs.RutinaDTO">
            <summary>
            Projection of a <c>Rutina</c> (training routine) entity with its associated exercises.
            </summary>
            <remarks>
            An active routine is identified by a <c>null</c> <see cref="P:BLL.DTOs.RutinaDTO.Hasta"/> value.
