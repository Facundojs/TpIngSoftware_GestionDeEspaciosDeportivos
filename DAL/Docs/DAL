        <member name="T:DAL.Impl.SqlServer.UnitOfWork">
            <summary>
            Implements the Unit of Work pattern for SQL Server.
            Manages a single <see cref="T:System.Data.SqlClient.SqlConnection"/> and <see cref="T:System.Data.SqlClient.SqlTransaction"/> shared across
            all enrolled repositories for the duration of one logical operation.
            </summary>
            <remarks>
            <para>
            Obtain an instance via <see cref="M:DAL.Factory.DalFactory.CreateUnitOfWork"/>.
            Usage pattern:
            <code>
            using (var uow = DalFactory.CreateUnitOfWork())
            {
                uow.BeginTransaction();
                // ...operations on uow.*Repository...
                uow.Commit();
            }
            </code>
            </para>
            <para>
            After <see cref="M:DAL.Impl.SqlServer.UnitOfWork.Commit"/> or <see cref="M:DAL.Impl.SqlServer.UnitOfWork.Rollback"/>, the instance is <em>spent</em>
            and cannot be reused; <see cref="M:DAL.Impl.SqlServer.UnitOfWork.BeginTransaction"/> will throw <see cref="T:System.ObjectDisposedException"/>.
            <see cref="M:DAL.Impl.SqlServer.UnitOfWork.Dispose"/> will roll back any uncommitted transaction if the <c>using</c> block
            exits without an explicit commit.
            </para>
            </remarks>
        </member>
        <member name="M:DAL.Impl.SqlServer.UnitOfWork.#ctor">
            <summary>Constructs all repository instances without opening a connection.</summary>
        </member>
        <member name="M:DAL.Impl.SqlServer.UnitOfWork.BeginTransaction">
            <summary>
            Opens the shared connection and begins a database transaction, injecting both into all repositories.
            </summary>
            <exception cref="T:System.ObjectDisposedException">Thrown if the instance has already been disposed or spent.</exception>
            <exception cref="T:System.InvalidOperationException">Thrown if a transaction is already active on this instance.</exception>
        </member>
        <member name="M:DAL.Impl.SqlServer.UnitOfWork.Commit">
            <summary>Commits the active transaction and closes the shared connection.</summary>
            <exception cref="T:System.InvalidOperationException">Thrown if no transaction is active.</exception>
        </member>
        <member name="M:DAL.Impl.SqlServer.UnitOfWork.Rollback">
            <summary>
            Rolls back the active transaction and closes the shared connection.
            Safe to call even when no transaction is active (no-op in that case).
            </summary>
        </member>
        <member name="M:DAL.Impl.SqlServer.UnitOfWork.Dispose">
            <summary>
            Rolls back any uncommitted transaction and releases all resources.
            Called automatically at the end of a <c>using</c> block.
            </summary>
        </member>
